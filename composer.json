{
    "name": "actengage/sluggable",
    "description": "A simple trait to ensure Laravel models have slugs.",
    "keywords": ["slugs", "sluggable"],
    "license": "MIT",
    "authors": [
        {
            "name": "Justin Kimbrell",
            "email": "jkimbrell@actengage.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "mockery/mockery": "^1.1",
        "phpunit/phpunit": "^10.0",
        "larastan/larastan": "^3.9",
        "rector/rector": "^2.3",
        "laravel/pint": "^1.29",
        "pestphp/pest": "*",
        "pestphp/pest-plugin-laravel": "*",
        "laravel/boost": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Actengage\\Sluggable\\": "src/",
            "Tests\\": "tests/"
        }
    },
    "autoload-dev": {
        "psr-4" : {
            "Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                
            ],
            "aliases": {

            }
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
